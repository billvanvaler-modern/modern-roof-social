# Copy this to .env and fill in your values
# NEVER share .env or commit it to git

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio (SMS input)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+18446168443
BILL_PHONE_NUMBER=+1...

# GoHighLevel
GHL_LOCATION_ID=...
GHL_PRIVATE_TOKEN=...

# Facebook account ID from GHL Social Planner
GHL_FB_ACCOUNT_ID=...
GHL_IG_ACCOUNT_ID=...
GHL_TIKTOK_ACCOUNT_ID=...
GHL_LINKEDIN_ACCOUNT_ID=...
GHL_GOOGLE_ACCOUNT_ID=...

# App
PORT=3000
# Set to 'draft' so posts land in GHL for review before publishing
# Change to 'scheduled' when you trust the system fully
GHL_POST_STATUS=draft

# Your timezone
TIMEZONE=America/Indiana/Indianapolis
